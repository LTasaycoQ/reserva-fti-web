<div id="booking-engine-container" class="flex w-[40%] justify-center items-center pt-[50px] w-full"></div>

<script is:inline>
  let bookingInitialized = false;

  document.addEventListener("astro:before-preparation", () => {
    bookingInitialized = false;
  });

  function initBooking() {
    if (bookingInitialized) return;
    bookingInitialized = true;

    const container = document.querySelector("#booking-engine-container");
    if (!container) return;
    container.innerHTML = "";

    if (typeof FNSbooking !== "undefined") {
      let fnsbooking = new FNSbooking(
        "2992",
        "#booking-engine-container",
        "es",
        "#d99e23",
        false,
        false,
        "0px",
        "0px",
      );
      fnsbooking.show();
    } else {
      console.error("FNSbooking no se cargó correctamente");
    }
  }

  document.addEventListener("astro:page-load", initBooking);
</script>