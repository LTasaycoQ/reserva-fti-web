---
const currentLocale = Astro.currentLocale || 'es';

const translations = {
    es: { idioma: "es" },
    en: { idioma: "en" }
};

const t = translations[currentLocale as keyof typeof translations] || translations.es;
---

<div 
    data-idioma={t.idioma} 
    id="booking-engine-container" 
    class="booking-container"
></div>

<style>
    @reference "tailwindcss";

    .booking-container {
        display: flex;
        width: 100%;
        justify-content: center;
        align-items: center;
        padding-top: 50px;
        min-height: 150px;
    }
</style>

<script is:inline>
  window.safeInit('booking', () => {
    const container = document.querySelector("#booking-engine-container");
    
    if (!container) return; 

    if (typeof FNSbooking === "undefined") return false;

    container.innerHTML = "";
    const idioma = container.dataset.idioma || "es";

    let fnsbooking = new FNSbooking(
      "2992",
      "#booking-engine-container",
      idioma,
      "#d99e23",
      false,
      false,
      "0px",
      "0px",
    );
    fnsbooking.show();

    container.style.display = 'none';
    container.offsetHeight; 
    container.style.display = 'flex';
  });
</script>