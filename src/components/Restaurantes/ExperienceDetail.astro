---
import { Image } from "astro:assets";

interface Section {
  title: string;
  content: string;
  image: string;
  alt: string;
}

const restaurantImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/restaurante/*.webp',
  { eager: true }
);

const currentLocale = Astro.currentLocale || 'es';

const restaurantDataEs = import.meta.glob<any>('../../content/restaurant-info.md', { eager: true });
const restaurantDataEn = import.meta.glob<any>('../../content/restaurant-info-en.md', { eager: true });

const restaurantData = currentLocale === 'en'
  ? Object.values(restaurantDataEn)[0]
  : Object.values(restaurantDataEs)[0];

const { frontmatter } = restaurantData;
const sections = frontmatter.sections as Section[];

function getImage(path: string): ImageMetadata {
  const filename = path.split('/').pop();
  const key = `../../assets/restaurante/${filename}`;
  return restaurantImages[key]?.default;
}
---

<div class="restaurant-info-container">
  {
    sections.map((section) => (
      <div class="info-item">
        <div class="text-column-wrapper">
          <div class="texto">
            <p class="text-letra">
              {section.content}
            </p>
          </div>
        </div>
        
        <div class="image-column-wrapper">
          <Image
            src={getImage(section.image)}
            format="png"
            alt={section.alt}
            loading="lazy"
            width={490}
            height={350}
            class="restaurant-section-img"
          />
        </div>
      </div>
    ))
  }
</div>

<style>
  /* --- CONTENEDOR CONTORNO GLOBAL (85%) --- */
  .restaurant-info-container {
    width: 85%; /* w-[85%] */
    margin-left: auto;
    margin-right: auto;
    box-sizing: border-box;
  }

  /* --- FILA DE CONTENIDO (FLEX DESKTOP) --- */
  .info-item {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 50px; /* gap-[50px] */
    margin-bottom: 45px;
    width: 100%;
    box-sizing: border-box;
  }

  /* --- COLUMNA DE TEXTO --- */
  .text-column-wrapper {
    width: 50%; /* w-[50%] */
    max-width: 590px; /* xl:w-[590px] */
    display: flex;
    justify-content: center;
    align-items: center;
    box-sizing: border-box;
  }

  .texto {
    padding: 17px; /* p-[17px] */
    width: 100%; /* w-[100%] */
    box-sizing: border-box;
  }

  .text-letra {
    font-family: var(--font-family-poppins), sans-serif;
    text-align: start; /* text-start */
    color: #6b7280; /* text-gray-500 */
    font-size: 15.6px; /* text-[15.6px] */
    line-height: 1.6;
    margin: 0;
  }

  /* --- COLUMNA DE IMAGEN --- */
  .image-column-wrapper {
    width: 50%; /* Balance simétrico nativo */
    max-width: 490px; /* xl:w-[490px] */
    display: flex;
    justify-content: center;
    align-items: center;
    box-sizing: border-box;
  }

  .restaurant-section-img {
    width: 100%;
    max-width: 490px;
    height: auto;
    object-fit: cover;
    display: block;
  }

  /* --- LÓGICA DE BORDES ALTERNOS EN DESKTOP --- */
  .info-item:nth-child(even) {
    flex-direction: row-reverse; /* Alternancia de orden */
  }

  .info-item:nth-child(even) .texto {
    border-top: 1px solid #d4af37;
    border-left: 1px solid #d4af37;
  }

  .info-item:nth-child(odd) .texto {
    border-bottom: 1px solid #d4af37;
    border-right: 1px solid #d4af37;
  }

  /* --- MEDIA QUERIES (RESPONSIVE SEGURO PARA IPAD) --- */

  /* Tablets e iPads (max-width: 768px -> max-md) */
  @media (max-width: 768px) {
    .info-item, 
    .info-item:nth-child(even) {
      flex-direction: column; /* max-md:flex-wrap apilado vertical limpia */
      gap: 30px;
      margin-bottom: 60px; /* Mayor separación entre secciones en vertical */
    }

    .text-column-wrapper {
      width: 90%; /* max-md:w-[90%] */
      max-width: 100%;
    }

    .image-column-wrapper {
      width: 90%;
      max-width: 100%;
    }

    .restaurant-section-img {
      max-width: 100%;
    }
    
    /* Mantenemos la elegancia de los bordes decorativos en mobile */
    .info-item:nth-child(even) .texto {
      border-top: 1px solid #d4af37;
      border-left: 1px solid #d4af37;
    }
  }

  /* Pantallas muy angostas o móviles chicos (max-width: 480px) */
  @media (max-width: 480px) {
    .restaurant-info-container {
      width: 90%; /* Damos un poco más de margen en los extremos */
    }
    
    .text-column-wrapper,
    .image-column-wrapper {
      width: 100%;
    }
  }
</style>