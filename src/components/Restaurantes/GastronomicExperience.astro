---
import ExperienceDetail from "./ExperienceDetail.astro"

const currentLocale = Astro.currentLocale || 'es';

const translations = {
  es: {
    title: "Nos enfocamos en hacer que su experiencia gastronómica sea extraordinaria!"
  },
  en: {
    title: "We focus on making your dining experience extraordinary!"
  }
};

const t = translations[currentLocale as keyof typeof translations] || translations.es;
---

<section class="dining-experience-section">
  <h2 class="title title--feature">{t.title}</h2>
  <ExperienceDetail />
</section>

<style>
  /* --- CONTENEDOR PRINCIPAL SECCIÓN --- */
  .dining-experience-section {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    
    margin-top: 80px;
    margin-bottom: 80px;
    margin-left: auto; 
    margin-right: auto; 
    padding-bottom: 60px; 
    
    width: 100%;
    max-width: 1200px; 
    padding-left: 24px; 
    padding-right: 24px;
    box-sizing: border-box;
  }

  .title--feature {
    font-size: 26px;
    margin-top: 0;
    margin-bottom: 70px;
    font-weight: 300;
    color: #CEAD2F;
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .dining-experience-section {
      margin-top: 60px;
      margin-bottom: 60px;
      padding-bottom: 40px;
    }

    .title--feature {
      font-size: 22px;
      margin-bottom: 50px;
    }
  }

  @media (max-width: 480px) {
    .dining-experience-section {
      margin-top: 40px;
      margin-bottom: 40px;
      padding-left: 16px;
      padding-right: 16px;
    }

    .title--feature {
      font-size: 19px;
      margin-bottom: 40px;
    }
  }
</style>