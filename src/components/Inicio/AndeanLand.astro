---
import { Image } from "astro:assets";
import pasadizVert from "../../assets/images/pasadizo-vert.webp";

const currentLocale = Astro.currentLocale || 'es';

const translations = {
  es: {
    tagline: "UNA ESTADÍA EN EL HOTEL TERRA ANDINA TE SITÚA EN EL CORAZÓN DE CUSCO",
    buttonText: "CONOCENOS",
    title: "TERRA ANDINA",
    subtitle: "MANSION COLONIAL",
    description: "Una <strong>mansión colonial</strong> en el distrito histórico de la antigua capital del Imperio Inca, <strong>Cusco, Perú</strong>. <em>Terra Andina Colonial Mansion</em> es un <strong>hotel de primera clase</strong> ubicado a media cuadra de la encantadora Plaza San Pedro, el Mercado de San Pedro (diseñado por Eiffel), la Iglesia de San Pedro y a solo cuatro cuadras de la <strong>Plaza de Armas de Cusco</strong>.",
    benefits: [
      "Es el punto de partida perfecto para hacer de su visita a Cusco y Machu Picchu una experiencia inolvidable.",
      "Nuestro personal amable y profesional le espera para garantizarle una estancia agradable."
    ]
  },
  en: {
    tagline: "A STAY AT TERRA ANDINA HOTEL PLACES YOU IN THE HEART OF CUSCO",
    buttonText: "ABOUT US",
    title: "TERRA ANDINA",
    subtitle: "COLONIAL MANSION",
    description: "A <strong>colonial mansion</strong> in the historic district of the ancient capital of the Inca Empire, <strong>Cusco, Peru</strong>. <em>Terra Andina Colonial Mansion</em> is a <strong>first-class hotel</strong> located half a block from the charming Plaza San Pedro, the San Pedro Market (designed by Eiffel), the Church of San Pedro and only four blocks from <strong>Cusco's Main Square</strong>.",
    benefits: [
      "It is the perfect starting point to make your visit to Cusco and Machu Picchu an unforgettable experience.",
      "Our friendly and professional staff awaits you to guarantee you a pleasant stay."
    ]
  }
};

const t = translations[currentLocale as keyof typeof translations];
---

<section class="hotel-section">
  <div class="hotel-section__container">
    
    <div class="hotel-section__tagline-box">
      <h3 class="tagline-title">
        {t.tagline}
      </h3>
      <a href="#" class="btn-about">
        <i class="bi bi-arrow-right"></i>
        {t.buttonText}
      </a>
    </div>
    
    <div class="hotel-intro__content">
      <h2 class="intro-title">
        {t.title} <br />
        {t.subtitle}
      </h2>
      <p class="intro-description" set:html={t.description}></p>
      
      <ul class="benefits-list">
        {t.benefits.map((benefit) => (
          <li class="benefit-item">
            <i class="bi bi-check-circle-fill icon-check"></i>
            <span>{benefit}</span>
          </li>
        ))}
      </ul>
    </div>
    
    <div class="hotel-section__image-box">
      <Image loading="lazy" class="intro-image" src={pasadizVert} alt="pasadizo-terraAndinaHotel"/>
    </div>
    
  </div>
</section>

<style>
  .hotel-section {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding-top: 40px;
  }

  .hotel-section__container {
    width: 80%;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 30px;
    padding: 2em;
  }

  .hotel-section__tagline-box {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 20px;
  }

  .tagline-title {
    text-align: start;
    font-size: 1.875rem;
    line-height: 2.25rem;
    margin: 0;
  }

  .btn-about {
    background-color: #9d8132;
    font-weight: 400;
    border-radius: 5px;
    color: #ffffff;
    width: 170px;
    justify-content: center;
    padding: 10px;
    display: flex;
    gap: 10px;
    text-decoration: none;
    transition: background-color 0.2s ease-in-out;
  }

  .btn-about:hover {
    background-color: #bfa355;
  }

  .hotel-intro__content {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .intro-title {
    font-size: 2.25rem;
    line-height: 2.5rem;
    margin: 0;
  }

  .intro-description {
    color: #374151;
    font-size: 15px;
    line-height: 1.5;
    margin: 0;
  }

  .benefits-list {
    font-size: 13px;
    color: #6b7280; 
    padding-top: 20px;
    list-style: none;
    margin: 0;
    padding-left: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .benefit-item {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .icon-check {
    color: #991b1b; 
    flex-shrink: 0;
  }

  .hotel-section__image-box {
    padding: 10px;
    background-color: #ffffff;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    display: flex;
  }

  .intro-image {
    width: 100%;
    max-width: 52em;
    height: auto;
    display: block;
  }

  @media (max-width: 1023px) {
    .hotel-section__container {
      width: 100%;
    }
  }

  @media (max-width: 767px) {
    .hotel-section__container {
      flex-direction: column;
    }

    .hotel-section__tagline-box {
      align-items: center;
    }

    .tagline-title {
      text-align: center;
    }
  }
</style>