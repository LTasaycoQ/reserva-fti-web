---
import SectionImagen from "./sectionImagen.astro";

const currentLocale = Astro.currentLocale || 'es';

const translations = {
  es: {
    title: {
      part1: "UNA CASONA COLONIAL",
      part2: "EN EL CENTRO HISTORICO DE CUSCO"
    }
  },
  en: {
    title: {
      part1: "A COLONIAL MANSION",
      part2: "IN THE HISTORIC CENTER OF CUSCO"
    }
  }
};

const t = translations[currentLocale as keyof typeof translations] || translations.es;
---

<section class="casona-intro-section">
  <h1 class="title casona-main-title">
    {t.title.part1} <br />
    {t.title.part2}
  </h1>
  <SectionImagen />
</section>

<style>
  /* --- CONTENEDOR DE LA SECCIÓN --- */
  .casona-intro-section {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    box-sizing: border-box;
  }

  /* --- H1 ENCABEZADO PRINCIPAL --- */
  .casona-main-title {
    text-align: center;
    padding: 4px;
    padding-top: 32px; /* Equivalente exacto a pt-[2em] (2 * 16px de base) */
    padding-bottom: 12.8px; /* Equivalente exacto a pb-[0.8em] (0.8 * 16px) */
    font-size: 2.25rem; /* text-4xl estándar */
    line-height: 1.3;
    margin: 0;
    letter-spacing: 0.5px;
  }

  /* --- ESTILOS DE RESERVA / INTERNOS --- */
  .rooms {
    text-align: center;
  }
  
  .rooms__desc {
    margin-bottom: 40px;
    color: #777;
  }

  /* --- MEDIA QUERIES (RESPONSIVE SEGURO) --- */

  /* Tablets e iPads (max-width: 768px) */
  @media (max-width: 768px) {
    .casona-main-title {
      font-size: 1.85rem; /* Ajuste para evitar que el texto se rompa toscamente en iPad */
      padding-top: 24px;
    }
  }

  /* Móviles (max-width: 480px) */
  @media (max-width: 480px) {
    .casona-main-title {
      font-size: 1.5rem; /* Escala optimizada para pantallas pequeñas */
      padding-left: 10px;
      padding-right: 10px;
    }
  }
</style>