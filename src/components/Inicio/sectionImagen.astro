---
import { Image } from "astro:assets";
import barVert from "../../assets/images/Bar-vert.webp";
import repcionTah from "../../assets/images/repcion-tah.webp";

const currentLocale = Astro.currentLocale || 'es';

const translations = {
  es: {
    hotelLabel: "Nuestro Hotel"
  },
  en: {
    hotelLabel: "Our Hotel"
  }
};

const t = translations[currentLocale as keyof typeof translations] || translations.es;
---

<div class="hotel-gallery-wrapper">
  
  <div class="gallery-photo-card photo-card-vertical">
    <Image class="gallery-img-file img-bar" loading="lazy" src={barVert} alt="bar-vert" />
  </div>
  
  <div class="container-seccion-imagenes gallery-photo-group">
    <div class="gallery-photo-card photo-card-horizontal">
      <Image class="gallery-img-file img-reception" loading="lazy" src={repcionTah} alt="repcion-tah" />
    </div>
    <span class="span-text hotel-gallery-label">{t.hotelLabel}</span>
  </div>

</div>

<style>
  /* --- CONTENEDOR PRINCIPAL FLUIDO --- */
  .hotel-gallery-wrapper {
    width: 100%;
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 35px; /* gap-[35px] */
    padding: 32px; /* p-[2em] (2 * 16px) */
    box-sizing: border-box;
  }

  /* --- MARCOS DE LAS IMÁGENES (TARJETAS BLANCAS) --- */
  .gallery-photo-card {
    padding: 13px; /* p-[13px] */
    background-color: #ffffff; /* bg-white */
    box-sizing: border-box;
    
    /* Sombra refinada de alta gama compatible con WebKit/Safari */
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); 
  }

  /* --- ARCHIVOS DE IMAGEN INTERNOS (ESTABILIDAD EN EM -> PX) --- */
  .gallery-img-file {
    height: auto;
    object-fit: cover;
    display: block;
  }

  /* Equivalente exacto a w-[18em] (18 * 16px = 288px) */
  .img-bar {
    width: 288px;
    max-width: 100%;
    flex-shrink: 0;
  }

  /* Equivalente exacto a w-[30em] (30 * 16px = 480px) */
  .img-reception {
    width: 480px;
    max-width: 100%;
    flex-shrink: 0;
  }

  /* --- CONTENEDOR DERECHO (RECEPCIÓN + TEXTO SUPERPUESTO) --- */
  .gallery-photo-group {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  /* --- TIPOGRAFÍA Y TEXTO EN ORO --- */
  .hotel-gallery-label {
    position: relative;
    top: 30px; /* relative top-[30px] */
    color: #d19e08; /* text-[#d19e08] */
    font-size: 64px; /* text-[64px] */
    text-align: left;
    line-height: 1;
    display: block;
    font-family: var(--font-family-tercer);
    font-weight: lighter;
    font-style: normal;
  }

  /* --- MEDIA QUERIES (RESPONSIVE SEGURO PARA IPAD Y MÓVILES) --- */

  /* Tablets e iPads en vertical (max-width: 768px -> max-md) */
  @media (max-width: 768px) {
    .hotel-gallery-wrapper {
      flex-direction: column; /* max-md:flex-col */
      gap: 50px; /* Mayor separación al apilarse verticalmente */
    }

    .photo-card-vertical,
    .photo-card-horizontal {
      width: 100%;
      max-width: 480px; /* Alineamos ambas cajas al mismo ancho máximo en móvil */
    }

    .img-bar, 
    .img-reception {
      width: 100%; /* Las imágenes se expanden limpiamente en su contenedor */
    }
  }

  @media (max-width: 640px) {
    .container-seccion-imagenes {
      text-align: center; 
      align-items: center;
    }

    .hotel-gallery-label {
      top: 35px; 
      font-size: 50px; 
      text-align: center; 
    }
  }
</style>