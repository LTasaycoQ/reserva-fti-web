---
import LanguageSelector from "./LanguageSelector.astro";
---

<div class="header-top">
  <div class="header-top__container">
    <a href="mailto:ventas@terraandinahotel.com" class="header-top__link email">
      <i class="bi bi-envelope"></i>
      ventas@terraandinahotel.com
    </a>
    <a href="https://wa.link/0x6gpq" target="_blank" class="header-top__link whatsapp">
      <svg xmlns="http://www.w3.org/2000/svg" class="svg-telephone header-icon_telephono" viewBox="0 0 24 24" width="16" height="16" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    <path d="M14.05 2a9 9 0 0 1 7.95 7.95" />
                    <path d="M14.05 6a5 5 0 0 1 3.95 3.95" />
                    </svg>
      +51 987 945 817
    </a>
    <LanguageSelector />
  </div>
</div>

<style>
  .header-top {
    background: var(--primary-color);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .header-top__container {
    display: flex;
    padding: 10px;
    align-items: center;
    gap: 40px;
    justify-content: flex-end;
    width: 100%;

  }

  .header-top__link {
    color: #ffffff;
    text-decoration: none;
    display: flex;
    gap: 10px;
    position: relative;
    transition: color 0.2s ease-in-out;
  }

  .header-top__link.whatsapp {
    gap: 8px;
  }

  .header-top__link.email:hover {
    color: #bfdbfe;
  }

  .header-top__link.whatsapp:hover {
    color: #86efac; 
  }


  @media (max-width: 767px) {
    .header-top {
      display: none !important;
    }
  }

  @media (min-width: 1280px) {
    .header-top__container {
      width: 90%;
    }
  }

  @media (min-width: 1536px) {
    .header-top__container {
      width: 80%;
    }
  }
</style>