---
const imagen = [
    "https://res.cloudinary.com/dlgeap8h0/image/upload/f_auto,q_auto/v1779832041/baner-terra-mob_muiuxw.webp",
    "https://res.cloudinary.com/dlgeap8h0/image/upload/f_auto,q_auto/v1779832041/interra-intro_ozbfsa.webp",
    "https://res.cloudinary.com/dlgeap8h0/image/upload/f_auto,q_auto/v1779832041/Salon-masajes-2_okkmuv.webp",
    "https://res.cloudinary.com/dlgeap8h0/image/upload/f_auto,q_auto/v1779832041/fachada_goirco.webp",
    "https://res.cloudinary.com/dlgeap8h0/image/upload/f_auto,q_auto/v1778863909/secun1_mjzzjh.jpg",
]
---
<section class="fondo-animado">
  {
    imagen.map((item, index) => (
      <div class={`container-imagen ${index === 0 ? 'active' : ''}`}>
        <img class="imagen-hero" src={item} alt={`Slide ${index + 1}`} />
      </div>
    ))
  }
</section>

<style>
    .fondo-animado {
        position: relative;
        width: 100%;
        height: 43em;
        overflow: hidden;
    }
    .container-imagen {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        transition: opacity 1s ease-in-out;
        z-index: 1;
    }
    .container-imagen.active {
        opacity: 1;
        z-index: 2;
    }
    .imagen-hero {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: bottom;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const slides = document.querySelectorAll('.container-imagen');
        let currentSlide = 0;
        const intervalTime = 4000;
        function nextSlide() {
            slides[currentSlide].classList.remove('active');
            
            currentSlide = (currentSlide + 1) % slides.length;
            
            slides[currentSlide].classList.add('active');
        }

        setInterval(nextSlide, intervalTime);
    });
</script>