---
import { Image } from "astro:assets";
import RoomIncludes from "./RoomIncludes.astro";
import { getRoomsData } from "../../content/RoomClasic/service";

const roomImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/rooms/*.webp',
  { eager: true }
);

const currentLocale = Astro.currentLocale || 'es';
const roomsData = getRoomsData(currentLocale);

function getImage(path: string): ImageMetadata {
  const filename = path.split('/').pop();
  const key = `../../assets/rooms/${filename}`;
  return roomImages[key]?.default;
}
---

{
  roomsData.map((room) => {
    const half = Math.ceil(room.services.length / 2);
    const col1 = room.services.slice(0, half);
    const col2 = room.services.slice(half);
    return (
      <section class="room-section-card">
        <h2 class="room-card-title font-title">
          {room.title}
        </h2>
        
        <div class="slider-wrapper">
          <button aria-label="Anterior" class="prevBtn slider-nav-btn">
            <i class="bi bi-caret-left-fill" />
          </button>
          
          <div class="slider__rooms">
            {room.images.map((img) => (
              <Image
                src={getImage(img)}
                alt={room.title}
                format="png"
                width={384}
                height={280}
                class="slider-image-item"
                draggable={false}
                loading="lazy"
              />
            ))}
          </div>
          
          <button aria-label="Siguiente" class="nextBtn slider-nav-btn">
            <i class="bi bi-caret-right-fill" />
          </button>
        </div>
        
        <div class="lista__detail info-container">
          <RoomIncludes />
        </div>
        
        {room.titleService && (
          <h3 class="room-services-subtitle">{room.titleService}</h3>
        )}
        
        {room.services.length > 0 && (
          <div class="lista__detail services-grid">
            <ul class="services-column">
              {col1.map((item) => (
                <li class="service-item">
                  <i class="bi bi-check-lg check-icon" />
                  <span class="service-text">{item}</span>
                </li>
              ))}
            </ul>
            <ul class="services-column">
              {col2.map((item) => (
                <li class="service-item">
                  <i class="bi bi-check-lg check-icon" />
                  <span class="service-text">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </section>
    );
  })
}

<style>
  .room-section-card {
    margin-bottom: 80px; /* mb-20 */
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .room-card-title {
    color: #374151; 
    font-size: 1.8rem;
    margin-top: 40px;
    margin-bottom: 24px;
    font-weight: normal;
  }

  .slider-wrapper {
    width: 80%;
    padding: 15px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 30px;
    margin-bottom: 32px; 
    box-sizing: border-box;
  }

  .slider__rooms {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    overflow-x: scroll;
    scroll-behavior: smooth;
    gap: 20px;
    width: 78%;
    cursor: grab;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; 
  }

  .slider__rooms::-webkit-scrollbar {
    display: none;
  }

  .slider-image-item {
    width: 24em;
    height: auto;
    object-fit: cover;
    pointer-events: none;
    user-select: none;
    flex-shrink: 0;
  }

  .slider-nav-btn {
    border: none;
    background: transparent;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .slider-nav-btn i {
    background-color: #701a1a;
    color: #ffffff;
    padding: 8px;
    border-radius: 9999px;
    font-size: 18px;
    display: inline-flex;
  }

  /* --- LISTAS DE ETALLES Y SERVICIOS --- */
  .lista__detail {
    margin-bottom: 50px;
    margin-top: 40px;
  }

  .info-container {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .room-services-subtitle {
    color: #374151;
    font-size: 1.4rem;
    margin-bottom: 16px;
    font-weight: normal;
  }

  .services-grid {
    font-size: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 40px;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .services-column {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .service-item {
    display: flex;
    gap: 10px;
    text-align: start;
    align-items: center;
    justify-content: center;
  }

  .service-text {
    color: #4b5563; /* text-gray-600 */
  }

  .check-icon {
    color: #9E2222;
    font-size: 18px;
  }

  /* --- RESPONSIVE DESIGN (MEDIA QUERIES) --- */
  @media (max-width: 1024px) {
    .services-column {
      width: 85%; /* max-lg:w-[85%] */
    }
  }

  @media (max-width: 768px) {
    .slider-wrapper {
      width: 100%; /* max-md:w-[100%] */
    }
    .slider__rooms {
      width: 100%; /* max-md:w-[100%] */
    }
  }
</style>

<script is:inline>
  // Enlazamos de forma segura usando el helper global unificado
  window.safeInit('rooms-detail-sliders', () => {
    const sections = document.querySelectorAll(".room-section-card");

    if (sections.length === 0) return;

    sections.forEach((section) => {
      const slider = section.querySelector(".slider__rooms");
      const prevBtn = section.querySelector(".prevBtn");
      const nextBtn = section.querySelector(".nextBtn");

      if (!slider || !prevBtn || !nextBtn) return;

      // Navegación asistida por botones
      prevBtn.addEventListener("click", () => {
        slider.scrollBy({ left: -300, behavior: "smooth" });
      });

      nextBtn.addEventListener("click", () => {
        slider.scrollBy({ left: 300, behavior: "smooth" });
      });

      // Lógica nativa de arrastre (Desktop Drag)
      let isDown = false;
      let startX;
      let scrollLeft;

      slider.addEventListener("mousedown", (e) => {
        isDown = true;
        slider.style.cursor = "grabbing";
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
      });

      slider.addEventListener("mouseleave", () => {
        isDown = false;
        slider.style.cursor = "grab";
      });

      slider.addEventListener("mouseup", () => {
        isDown = false;
        slider.style.cursor = "grab";
      });

      slider.addEventListener("mousemove", (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - slider.offsetLeft;
        const walk = (x - startX) * 1.5;
        slider.scrollLeft = scrollLeft - walk;
      });
    });
  });
</script>