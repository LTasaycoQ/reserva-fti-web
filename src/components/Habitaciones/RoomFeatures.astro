---
import AdditionalDetails from "./AdditionalDetails.astro";

const currentLocale = Astro.currentLocale || 'es';

const translations = {
  es: { title: "CARACTERISTICAS DE LAS HABITACIONES" },
  en: { title: "ROOM FEATURES" }
};

const t = translations[currentLocale as keyof typeof translations] || translations.es;
---

<section class="rooms-section">
  <div class="position__title">
    <h1 class="title">
      {t.title}
    </h1>
    <span class="title-divider"></span>
  </div>
  <AdditionalDetails/>
</section>

<style>
  .rooms-section {
    text-align: center;
    padding-bottom: 60px;
  }

  .position__title {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    margin-top: 40px;
    margin-bottom: 50px;
  }

  .title {
    color: #374151; 
    font-size: 1.9rem;
    margin-bottom: 16px;
    font-weight: normal; 
  }

  .title-divider {
    width: 250px;
    background-color: #F6A818;
    position: relative;
    top: -8px;
    height: 1px;
    display: block; /* Asegura el renderizado correcto del span vacío */
  }
</style>

<script is:inline>
  // Inicializador global seguro libre de duplicados
  window.safeInit('rooms-slider', () => {
    const sliders = document.querySelectorAll(".slider__rooms");
    
    if (sliders.length === 0) return;

    sliders.forEach((slider) => {
      // Evitamos duplicar clones en navegaciones consecutivas de Astro
      if (slider.dataset.cloned === "true") return;
      slider.dataset.cloned = "true";

      const prevBtn = slider.parentElement.querySelector(".prevBtn");
      const nextBtn = slider.parentElement.querySelector(".nextBtn");
      const images = Array.from(slider.children);
      
      if (images.length === 0) return;

      const firstClone = images[0].cloneNode(true);
      const lastClone = images[images.length - 1].cloneNode(true);
      
      slider.appendChild(firstClone);
      slider.insertBefore(lastClone, slider.firstChild);
      
      let currentIndex = 1;
      const totalSlides = images.length;
      
      const updateSlider = (smooth = true) => {
        const imageWidth = images[0].offsetWidth + 20;
        slider.style.scrollBehavior = smooth ? 'smooth' : 'auto';
        slider.scrollLeft = currentIndex * imageWidth;
      };
      
      updateSlider(false);
      
      if (nextBtn) {
        nextBtn.addEventListener("click", () => {
          currentIndex++;
          updateSlider(true);
        });
      }
      
      if (prevBtn) {
        prevBtn.addEventListener("click", () => {
          currentIndex--;
          updateSlider(true);
        });
      }
      
      slider.addEventListener("scrollend", () => {
        if (currentIndex === 0) {
          currentIndex = totalSlides;
          updateSlider(false);
        } else if (currentIndex === totalSlides + 1) {
          currentIndex = 1;
          updateSlider(false);
        }
      });
      
      /* --- DRAG / MOUSE MÓVIL --- */
      let isDragging = false;
      let startX, startScrollLeft;
      
      slider.addEventListener("mousedown", (e) => {
        isDragging = true;
        slider.style.cursor = 'grabbing';
        slider.style.scrollBehavior = 'auto';
        startX = e.pageX;
        startScrollLeft = slider.scrollLeft;
      });
      
      slider.addEventListener("mousemove", (e) => {
        if (!isDragging) return;
        e.preventDefault();
        const x = e.pageX;
        const walk = (startX - x) * 1.5;
        slider.scrollLeft = startScrollLeft + walk;
      });
      
      const stopDragging = () => {
        if (!isDragging) return;
        isDragging = false;
        slider.style.cursor = 'grab';
        const imageWidth = images[0].offsetWidth + 20;
        currentIndex = Math.round(slider.scrollLeft / imageWidth);
        updateSlider(true);
      };
      
      slider.addEventListener("mouseup", stopDragging);
      slider.addEventListener("mouseleave", stopDragging);
      
      /* --- PARCHE TOUCH GESTURES (IPAD/IPHONE) --- */
      slider.addEventListener("touchstart", (e) => {
        startX = e.touches[0].pageX;
        startScrollLeft = slider.scrollLeft;
      }, { passive: true });
      
      slider.addEventListener("touchmove", (e) => {
        const x = e.touches[0].pageX;
        const walk = (startX - x) * 1.5;
        slider.scrollLeft = startScrollLeft + walk;
      }, { passive: true });
      
      slider.addEventListener("touchend", () => {
        const imageWidth = images[0].offsetWidth + 20;
        currentIndex = Math.round(slider.scrollLeft / imageWidth);
        updateSlider(true);
      });
    });
  });
</script>