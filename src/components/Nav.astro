---
import { Image } from "astro:assets";
import logo from "../assets/logo/Logo-TAH-ENG.webp";

import LanguageSelector from "./LanguageSelector.astro";
const currentLocale = Astro.currentLocale || 'es';

const translations = {
  es: {
    hotel: "HOTEL",
    rooms: "HABITACIONES",
    restaurant: "RESTAURANTE",
    massage: "MASAJES",
    gallery: "GALERIA",
    contact: "CONTACTO"
  },
  en: {
    hotel: "HOTEL",
    rooms: "ROOMS",
    restaurant: "RESTAURANT",
    massage: "MASSAGE",
    gallery: "GALLERY",
    contact: "CONTACT"
  }
};

const t = translations[currentLocale as keyof typeof translations];

const getPath = (path: string) => {
  if (currentLocale === 'es') return path;
  return `/en${path}`;
};
---

<nav class="nav">
    <div class="menu-container">
        <div class="nav__logo">
            <a href={currentLocale === 'es' ? '/' : '/en'} class="logo-link" aria-label="Volver al inicio">
    <Image 
        src={logo}
        format="png"
        class="logo-img" 
        loading="eager" 
        alt="Logotipo de Terra Andina Colonial Mansion Hotel Cusco"
    />
</a>
        </div>

        <div class="desktop-menu">
            <ul class="nav__list">
                <li><a class="nav__link" href={getPath("/hotel")}>{t.hotel}</a></li>
                <li><a class="nav__link" href={getPath("/habitaciones")}>{t.rooms}</a></li>
                <li><a class="nav__link" href={getPath("/restaurante")}>{t.restaurant}</a></li>
                <li><a class="nav__link" href={getPath("/masajes")}>{t.massage}</a></li>
                <li><a class="nav__link" href={getPath("/galeria")}>{t.gallery}</a></li>
                <li><a class="nav__link" href={getPath("/contacto")}>{t.contact}</a></li>
            </ul>
        </div>

        <div class="actions-container">
            <div class="lang-desktop">
                <LanguageSelector/>
            </div>
            <div class="mobile-toggle-wrapper">
                <button id="open-modal" class="btn-menu-toggle open" aria-label="Abrir menú">
                    <svg
                        aria-hidden="true"
                        fill="#ffffff"
                        width="30"
                        height="30"
                        viewBox="0 0 1000 1000"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path d="M104 333H896C929 333 958 304 958 271S929 208 896 208H104C71 208 42 237 42 271S71 333 104 333ZM104 583H896C929 583 958 554 958 521S929 458 896 458H104C71 458 42 487 42 521S71 583 104 583ZM104 833H896C929 833 958 804 958 771S929 708 896 708H104C71 708 42 737 42 771S71 833 104 833Z"></path>
                    </svg>
                </button>
                
                <button id="close-modal" class="btn-menu-toggle close hidden" aria-label="Cerrar menú">
                    <svg
                        aria-hidden="true"
                        height="30"
                        width="30"
                        fill="#ffffff"
                        viewBox="0 0 1000 1000"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path d="M742 167L500 408 258 167C246 154 233 150 217 150 196 150 179 158 167 167 154 179 150 196 150 212 150 229 154 242 171 254L408 500 167 742C138 771 138 800 167 829 196 858 225 858 254 829L496 587 738 829C750 842 767 846 783 846 800 846 817 842 829 829 842 817 846 804 846 783 846 767 842 750 829 737L588 500 833 258C863 229 863 200 833 171 804 137 775 137 742 167Z"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</nav>

<div id="menu-responsive" class="menu-responsive" data-open="false">
    <div class="menu-responsive__content">
        <ul class="mobile-list">
            <li class="mobile-item">
                <a class="mobile-link" href={getPath("/hotel")}>{t.hotel}</a>
            </li>
            <li class="mobile-item">
                <a class="mobile-link" href={getPath("/habitaciones")}>{t.rooms}</a>
            </li>
            <li class="mobile-item">
                <a class="mobile-link" href={getPath("/restaurante")}>{t.restaurant}</a>
            </li>
            <li class="mobile-item">
                <a class="mobile-link" href={getPath("/masajes")}>{t.massage}</a>
            </li>
            <li class="mobile-item">
                <a class="mobile-link" href={getPath("/galeria")}>{t.gallery}</a>
            </li>
            <li class="mobile-item">
                <a class="mobile-link" href={getPath("/contacto")}>{t.contact}</a>
            </li>
        </ul>
    </div>
</div>

<style>
    .nav {
        width: 100%;
        padding: 16px 0px;
        border-top: 1px solid var(--secondary-color);
        background-color: var(--primary-color);
        display: flex;
        justify-content: center;
        align-items: center;
    }
    
    .menu-container {
        width: 100%;
        max-width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo-link {
        text-decoration: none;
        display: inline-block;
        border: none;
    }
    
    .logo-img {
        display: block;
        border: none;
        width: 130px;
    }

    .nav__list {
        display: flex;
        font-weight: 600;
        font-size: 16px;
        color: #ffffff;
        align-items: center;
        list-style: none;
    }

    .nav__link {
        text-decoration: none;
        color: #ffffff;
        padding-left:18px;
        padding-right:18px;
        transition: color 0.2s ease;
    }

    .nav__link:hover {
        color: #fa8e00;
    }

    .actions-container {
        display: none;
        align-items: center;
    }

    .mobile-toggle-wrapper {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .btn-menu-toggle {
        background-color: #470D0D;
        padding: 5px;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-menu-toggle.hidden {
        display: none !important;
    }

    .menu-responsive {
        position: relative;
        display: none;
        z-index: 9999;
        transform-origin: top;
        transform: scaleY(0);
        opacity: 0;
        transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease-in-out;
    }

    .menu-responsive[data-open="true"] {
        display: block;
        transform: scaleY(1);
        opacity: 1;
    }

    .menu-responsive__content {
        position: absolute;
        z-index: 9999;
        background-color: #1C1717;
        color: #ffffff;
        font-size: 13px;
        font-weight: 500;
        width: 100%;
    }

    .mobile-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .mobile-item {
        width: 100%;
        display: flex;
    }

    .mobile-link {
        display: block;
        width: 100%;
        padding: 10px 0 10px 40px;
        border-top: 1px solid #2D2828;
        background-color: transparent;
        color: #ffffff;
        text-decoration: none;
        transition: background-color 0.2s ease;
    }

    .mobile-link:hover {
        background-color: #3F444B;
    }


    @media (min-width: 768px) {
        .logo-img {
            width: 100%;
        }
        .lang-desktop {
            display: none;
        }
    }

    @media (min-width: 1024px) {
        .menu-container {
            padding-left: 70px;
            padding-right: 50px;
        }
        .mobile-toggle-wrapper {
            display: none; 
        }
        .menu-responsive {
            display: none !important; 
        }
    }
    @media (max-width: 1023px) {
        .desktop-menu {
            display: none; 
        }
        .menu-container {
            padding-left: 50px;
            padding-right: 50px;
        }
        .actions-container {
            display: flex;
            align-items: center;
        }
    }

    @media (max-width: 639px) {
        .menu-container {
            width: 90%;
            padding-left: 18px;
            padding-right: 18px;
        }
    }

    @media (min-width: 1280px) {
        .menu-container {
            width: 80%;
        }
       
    }

   
</style>

<script>
        const openBtn = document.getElementById("open-modal");
        const closeBtn = document.getElementById("close-modal");
        const menu = document.getElementById("menu-responsive");

        if (openBtn && closeBtn && menu) {
            openBtn.addEventListener("click", (e) => {
                e.preventDefault();
                menu.setAttribute("data-open", "true");
                openBtn.classList.add("hidden");
                closeBtn.classList.remove("hidden");
            });

            closeBtn.addEventListener("click", (e) => {
                e.preventDefault();
                menu.setAttribute("data-open", "false");
                openBtn.classList.remove("hidden");
                closeBtn.classList.add("hidden");
            });
        }
    
</script>