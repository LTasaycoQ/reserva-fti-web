---
const currentLocale = Astro.currentLocale || 'es';

const translations = {
  es: {
    form: {
      nombre: "Nombre",
      apellido: "Apellido",
      telefono: "Número Telefónico",
      email: "Email",
      mensaje: "Mensaje",
      enviar: "Enviar",
      enviando: "Enviando..."
    },
    contact: {
      titulo: "Contacto Hotel:",
      reservaciones: "Reservaciones:",
      recepcion: "Recepción:"
    },
    alerts: {
      successTitle: "¡Enviado!",
      successText: "Tu mensaje ha sido enviado con éxito.",
      errorTitle: "Error",
      errorText: "No pudimos enviar el mensaje. Intenta de nuevo."
    }
  },
  en: {
    form: {
      nombre: "Name",
      apellido: "Last Name",
      telefono: "Phone Number",
      email: "Email",
      mensaje: "Message",
      enviar: "Send",
      enviando: "Sending..."
    },
    contact: {
      titulo: "Hotel Contact:",
      reservaciones: "Reservations:",
      recepcion: "Front Desk:"
    },
    alerts: {
      successTitle: "Sent!",
      successText: "Your message has been sent successfully.",
      errorTitle: "Error",
      errorText: "We couldn't send the message. Please try again."
    }
  }
};

const t = translations[currentLocale as keyof typeof translations];
---
<section class="contacto-section">
  <div class="container-form">
    <form class="form-contacto">
      
      <input name="Nombre" placeholder={t.form.nombre} type="text" required/>
      <input name="Apellido"placeholder={t.form.apellido}type="text" required/>
      <input required name="Telefono" placeholder={t.form.telefono} type="number" />
      <input name="Email" placeholder={t.form.email} type="email" required  />
      <textarea name="Mensaje"  placeholder={t.form.mensaje} ></textarea>
      


      <div class="cf-turnstile" 
          data-sitekey="0x4AAAAAACw3a6WzSvEkH-5C" 
          data-theme="light"
          data-width="100%"> 
      </div>

      <span id="form-error" style="display: none;" class="field-error" aria-live="polite"></span>

      <button type="submit">{t.form.enviar}</button>
    </form>
  </div>

  <div class="container-info">
    <ul class="lista-contacto ">
      <li> <i class="bi bi-geo-alt-fill"></i>Calle Union 184, Cusco, Perú</li>
      <li><i class="bi bi-telephone-fill"></i>{t.contact.reservaciones} +51 987 945 817</li>
      <li><i class="bi bi-telephone-fill"></i>{t.contact.recepcion} +51 997 564 558</li>
      <li class=" contacto-titulo">{t.contact.titulo}</li>
      <li ><i class="bi bi-telephone-fill"></i>(51 - 84) 887-72950</li>
      <li ><i class="bi bi-telephone-fill"></i>(51 - 84) 887-72950</li>
      <li ><i class="bi bi-envelope"></i>reservas@TerraAndinaHotel.com</li>
    </ul>


    <div class="mapouter">
      <div class="gmap_canvas">
        <iframe 
          title="Mapa de ubicación Terra Andina Hotel"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3879.324357482811!2d-71.9845340239564!3d-13.515655571644783!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x916e1676e83d2897%3A0x908cd5f8e2442658!2sTerra%20Andina%20Mansion%20Colonial!5e0!3m2!1ses-419!2spe!4v1700000000000!5m2!1ses-419!2spe" 
          class="mapa-iframe"
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
  </div>
</section>


<style>
  .lista-contacto li{
      border-bottom: 1px solid rgb(233, 233, 233);
      font-family: var(--font-family-poppins);
  }
</style>




<script is:inline src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script is:inline define:vars={{ t }}>
  const URL = "https://mi-backend-workers.luistasayco3030.workers.dev/form-terra";
  const form = document.querySelector(".form-contacto");

  const rules = {
    Nombre:   { min: 2, max: 50,  pattern: /^[a-zA-ZÀ-ÿ\s]+$/,        msg: { es: "Solo letras, mínimo 2 caracteres.",   en: "Letters only, minimum 2 characters."    } },
    Apellido: { min: 2, max: 50,  pattern: /^[a-zA-ZÀ-ÿ\s]+$/,        msg: { es: "Solo letras, mínimo 2 caracteres.",   en: "Letters only, minimum 2 characters."    } },
    Telefono: { min: 7, max: 15,  pattern: /^\d{7,15}$/,               msg: { es: "Solo números, entre 7 y 15 dígitos.", en: "Numbers only, between 7 and 15 digits." } },
    Email:    {                   pattern: /^[^\s@]+@[^\s@]+\.[^\s@]+$/,msg: { es: "Ingresa un email válido.",            en: "Enter a valid email."                   } },
    Mensaje:  { min: 10, max: 500,                                      msg: { es: "Mínimo 10 caracteres, máximo 500.",  en: "Minimum 10 characters, maximum 500."    } },
  };

  const locale = document.documentElement.lang?.startsWith("en") ? "en" : "es";

  function showError(msg) {

    document.getElementById("form-error").style.display = 'block';
    document.getElementById("form-error").textContent = msg;
  }

  function clearError() {
    document.getElementById("form-error").style.display = "none";
    document.getElementById("form-error").textContent = "";
  }

  function validate(fields) {
    for (const field of fields) {
      const rule  = rules[field.name];
      const value = field.value.trim();

      if (!value) {
        showError(locale === "en"
          ? `${field.placeholder} is required.`
          : `${field.placeholder} es obligatorio.`
        );
        field.focus();
        return false;
      }
      if (rule?.min && value.length < rule.min) { showError(rule.msg[locale]); field.focus(); return false; }
      if (rule?.max && value.length > rule.max) { showError(rule.msg[locale]); field.focus(); return false; }
      if (rule?.pattern && !rule.pattern.test(value)) { showError(rule.msg[locale]); field.focus(); return false; }
    }
    clearError();
    return true;
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const fields = Object.keys(rules)
      .map(name => form.querySelector(`[name="${name}"]`))
      .filter(Boolean);

    if (!validate(fields)) return;

    const turnstileResponse = turnstile.getResponse();
    if (!turnstileResponse) {
      showError(locale === "en"
        ? "Please complete the security check."
        : "Por favor, completa la verificación de seguridad."
      );
      return;
    }

    clearError();

    const btn = form.querySelector("button");
    const originalText = btn.innerText;
    btn.innerText = t.form.enviando;
    btn.disabled  = true;

    const formData = new FormData(form);
    const data = {
      nombre:   formData.get("Nombre"),
      apellido: formData.get("Apellido"),
      telefono: formData.get("Telefono"),
      email:    formData.get("Email"),
      mensaje:  formData.get("Mensaje"),
      captcha:  turnstileResponse
    };

    try {
      await fetch(URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      Swal.fire({
        title: t.alerts.successTitle,
        text:  t.alerts.successText,
        icon:  "success",
        confirmButtonColor: "#C08E1F"
      });

      form.reset();
      turnstile.reset();

    } catch (error) {
      Swal.fire({ title: t.alerts.errorTitle, icon: "error" });
    } finally {
      btn.innerText = originalText;
      btn.disabled  = false;
    }
  });
</script>

<style>
  .field-error {
    display: block;
    color: #e53e3e;
    font-size: 0.75rem;
    margin-bottom: 0.5rem;
    font-family: var(--font-family-poppins);
    min-height: 1rem;
  }
</style>