---
import { Image } from "astro:assets";
import masajes from "../../assets/images/massage2.webp";
import Salonmasajes from "../../assets/images/Salon-masajes-2.webp";

const currentLocale = Astro.currentLocale || 'es';

const translations = {
  es: {
    schedule: "Abierto todos los días de 8:00 a 22:00.",
    instructions: [
      "Por favor, haga su reserva con al menos 4 horas de antelación.",
      "Marque \"O\" para que le atienda un representative.",
      "Se requiere un depósito del 50 % al hacer la reserva.",
      "Las \"Manos Curativas\" estarán encantadas de atenderle. Consulte el reverso para ver los tipos de masajes."
    ]
  },
  en: {
    schedule: "Open daily from 8:00 AM to 10:00 PM.",
    instructions: [
      "Please make your reservation at least 4 hours in advance.",
      "Dial \"O\" to be attended by a representative.",
      "A 50% deposit is required when making your reservation.",
      "\"Healing Hands\" will be delighted to assist you. See the back for types of massages."
    ]
  }
};

const t = translations[currentLocale as keyof typeof translations] || translations.es;
---

<section class="section__open">
  <div class="spa-schedule-container">
    
    <div class="spa-info-column">
      <div class="spa-text-block">
        <h4 class="spa-schedule-title">
          {t.schedule}
        </h4>
        
        <ul class="spa-instructions-list">
          {t.instructions.map((instruction) => (
            <li class="spa-instruction-item">
              <i class="bi bi-check-lg check-spa-icon"></i>
              <span class="instruction-text">{instruction}</span>
            </li>
          ))}
        </ul>
      </div>
      
      <Image 
        class="spa-img-salon" 
        loading="lazy" 
        format="png"
        src={Salonmasajes} 
        alt="Salón de masajes" 
      />
    </div>
    
    <div class="spa-side-column">
      <Image 
        loading="lazy" 
        format="png"
        src={masajes} 
        class="spa-img-treatment" 
        alt="Tratamiento de masajes" 
      />
    </div>
    
  </div>
</section>

<style>
  /* --- CONTENEDOR SECCIÓN --- */
  .section__open {
    width: 100%;
    margin-top: 100px;
    display: flex;
    justify-content: center;
    align-items: center;
    padding-top: 50px;
    margin-bottom: 100px;
    font-family: "Poppins", sans-serif;
    box-sizing: border-box;
  }

  /* --- CONTENEDOR FLEX DE CONTENIDO --- */
  .spa-schedule-container {
    display: flex;
    flex-direction: row;
    gap: 30px;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 1200px;
    padding: 0 20px;
    box-sizing: border-box;
  }

  /* --- COLUMNA DE INFORMACIÓN (50%) --- */
  .spa-info-column {
    width: 50%;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .spa-text-block {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .spa-schedule-title {
    font-size: 1.25rem; /* text-xl */
    font-weight: 400; /* font-normal */
    color: #C28E26; /* text-[#C28E26] */
    margin: 0;
    text-align: left; /* Corregido conflicto anterior */
  }

  /* --- LISTA DE INSTRUCCIONES --- */
  .spa-instructions-list {
    display: flex;
    flex-direction: column;
    font-size: 16px;
    color: #374151; /* text-gray-700 */
    margin-top: 20px; /* mt-5 */
    padding: 0;
    list-style: none;
    gap: 12px; /* Separación sutil entre líneas */
  }

  .spa-instruction-item {
    display: flex;
    align-items: flex-start; /* Alinea el check arriba si el texto hace dos líneas */
    gap: 10px;
    text-align: left;
  }

  .check-spa-icon {
    color: #A37816; /* text-[#A37816] */
    font-size: 20px;
    line-height: 1;
    flex-shrink: 0;
  }

  .instruction-text {
    line-height: 1.5;
  }

  /* --- COLUMNA LATERAL DE IMAGEN (28%) --- */
  .spa-side-column {
    width: 28%;
    display: flex;
    justify-content: center;
  }

  /* --- OPTIMIZACIÓN DE IMÁGENES PARA WEBKIT (IPAD/SAFARI) --- */
  .spa-img-salon {
    width: 480px; /* Equivalente exacto a 30em */
    max-width: 100%;
    height: auto;
    object-fit: cover;
    flex-shrink: 0; /* Bloquea colapso en iOS */
  }

  .spa-img-treatment {
    width: 320px; /* Equivalente exacto a 20em */
    max-width: 100%;
    height: auto;
    object-fit: cover;
    flex-shrink: 0;
  }

  /* --- RESPONSIVE DESIGN (MEDIA QUERIES) --- */

  /* Tablets e iPads en Modo Vertical (max-width: 768px -> max-md) */
  @media (max-width: 768px) {
    .spa-schedule-container {
      flex-direction: column; /* Apilamiento vertical */
      gap: 40px;
    }

    .spa-info-column {
      width: 70%; /* max-md:w-[70%] */
    }

    .spa-side-column {
      width: 60%; /* max-md:w-[60%] */
    }

    .spa-img-salon,
    .spa-img-treatment {
      width: 100%; /* Permite que se adapten por completo al ancho de sus columnas en móvil */
    }
    
    .spa-schedule-title {
      text-align: center; /* Se ve mejor centrado al pasar a flujo vertical */
    }
  }

  /* Smartphones pequeños (max-width: 480px) */
  @media (max-width: 480px) {
    .spa-info-column {
      width: 100%;
    }

    .spa-side-column {
      width: 100%;
    }
  }
</style>