---
const currentLocale = Astro.currentLocale || "es";

const translations = {
  es: {
    services: [
      { name: "Masaje sueco restaurador", price: 50 },
      { name: "Masaje relajante y aromaterapia", price: 55 },
      { name: "Reflexología", price: 45 },
      { name: "Shiatsu japonés", price: 45 },
      { name: "Masaje terapéutico y deportivo", price: 45 },
    ],
  },
  en: {
    services: [
      { name: "Restoring Swedish Massage", price: 50 },
      { name: "Relaxation and Aromatherapy Massage", price: 55 },
      { name: "Shiatsu", price: 45 },
      { name: "Therapeutic and Sports Massage", price: 45 },
      { name: "Reflexology", price: 45 },
    ],
  },
};

const t = translations[currentLocale as keyof typeof translations] || translations.es;
---

<section class="price-list-section">
  <ul class="price-menu-container">
    {t.services.map((service) => (
      <li class="price-item">
        <span class="service-name-text">{service.name}</span>
     
      </li>
    ))}
  </ul>
</section>

<style>
  /* --- CONTENEDOR DE LA SECCIÓN --- */
  .price-list-section {
    display: flex;
    justify-content: center;
    padding-top: 60px;
    width: 100%;
    box-sizing: border-box;
  }

  /* --- MENÚ DE PRECIOS --- */
  .price-menu-container {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items:center;
    justify-content:center;
    font-size: 20px;
    color: #374151b4; /* text-gray-700 */
    width: 500px;
    max-width: 100%; /* Evita desbordamiento en pantallas móviles muy angostas */
    padding: 40px;
    margin: 0;
    text-align:center;
    list-style: none;
    box-sizing: border-box;
  }

  /* --- FILA INDIVIDUAL --- */
  .price-item {
    display: flex;
    text-align:center;
    align-items: center;justify-content: center;
    width: 100%;
  }

  .service-name-text {
    display:flex;
    justify-content:center;
    align-items:center;
    color: #1e3a46; /* text-[#4E5250] */
    font-family: var(--font-family-poppins), sans-serif;
    font-weight: 600; /* text-bold aproximado */
  }

  /* --- SEPARADOR DE PUNTOS EDITORIAL (LEADER DOTS) --- */
  .price-leader-dots {
    flex-grow: 1; /* flex-1 */
    margin: 0 12px; /* mx-3 */
    border-bottom: 1px dashed #912424; /* border-dashed border-[#912424] */
    height: 10px; /* Controla la altura para centrarse verticalmente con el texto */
  }

  .service-price-value {
    font-family: var(--font-family-poppins), sans-serif;
    font-weight: 500;
    color: #374151;
  }

  @media (max-width: 640px) {
    .price-menu-container {
      padding: 20px;
      font-size: 17px; /* Reducción ligera para prevenir saltos de línea agresivos en móviles */
    }

    .service-name-text {
      white-space: normal; /* Permite saltos de línea limpios si el nombre del masaje es muy largo en smartphones */
    }
  }
</style>