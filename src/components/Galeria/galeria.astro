---
interface Section {
  id: number;
  image: string;
  title: string;
}

const currentLocale = Astro.currentLocale || 'es';

const translations = {
  es: {
    title: "GALERÍA DE FOTOS",
    no_images: "No se encontraron imágenes en la galería."
  },
  en: {
    title: "PHOTO GALLERY",
    no_images: "No images found in the gallery."
  }
};

const t = translations[currentLocale as keyof typeof translations];
const roomsImport = import.meta.glob("../../content/galeria.md", { eager: true });
const roomsData = Object.values(roomsImport) as any[];
const sections: Section[] = roomsData[0]?.frontmatter?.fotos ?? [];
---

<section class="galeria-section">
    <div class="galeria-container">
        <div>
            <h1 class="galeria-title">{t.title}</h1>        
        </div>
    </div>
    
    <div 
        id="galeria-fotos" 
        class="galeria-grid"
        data-sections={JSON.stringify(sections)}
    >
        {
            sections.length > 0 ? (
                sections.map((foto, index) => (
                    <div 
                        class="galeria-item"
                        data-index={index}
                    >
                        <img 
                            src={foto.image} 
                            alt={foto.title} 
                            class="galeria-img"
                            loading="lazy"
                            decoding="async"
                        />
                        <div class="galeria-overlay">
                            <i class="bi bi-zoom-in zoom-icon"></i>
                        </div>
                    </div>
                ))
            ) : (
                <p class="no-images">{t.no_images}</p>
            )
        }
    </div>

    <dialog id="modal-galeria" class="galeria-modal">
        <div class="modal-container">
            <button id="close-modal-btn" class="modal-close">
                &times;
            </button>
            
            <div class="modal-nav">
                <button id="prev-btn" class="modal-nav-btn">
                    <i class="bi bi-caret-left-fill"></i>
                </button>

                <div class="modal-image-wrapper">
                    <img 
                        id="modal-img" 
                        src="" 
                        alt="" 
                        class="modal-image" 
                    />
                </div>

                <button id="next-btn" class="modal-nav-btn">
                    <i class="bi bi-caret-right-fill"></i>
                </button>
            </div>
        </div>
    </dialog>
</section>

<style is:global>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .galeria-section {
        width: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        margin-left: auto;
        margin-right: auto;
        padding: 3rem 1rem;
    }

    .galeria-container {
        width: 90%;
    }

    .galeria-title {
        font-size: 34px;
        color: #4b5563;
        margin-bottom: 2rem;
        font-weight: 600;
    }

    .galeria-grid {
        padding-top: 30px;
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        justify-items: center;
        width: 90%;
    }

    @media (min-width: 640px) {
        .galeria-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) {
        .galeria-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    .galeria-item {
        position: relative;
        overflow: hidden;
        border-radius: 20px;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        width: 100%;
        height: 250px;
        cursor: pointer;
        /* ✅ Fix iPadOS - fuerza GPU layer */
        -webkit-transform: translateZ(0);
        transform: translateZ(0);
        -webkit-backface-visibility: hidden;
        backface-visibility: hidden;
        isolation: isolate;
    }

    .galeria-img {
        width: 100%;
        height: 100%;
        background-color: #e5e7eb;
        object-fit: cover;
        transition: transform 0.7s ease;
        display: block;
        /* ✅ Fix iPadOS - fuerza repaint */
        -webkit-transform: translateZ(0);
        transform: translateZ(0);
        -webkit-backface-visibility: hidden;
        backface-visibility: hidden;
    }

    .galeria-item:hover .galeria-img {
        transform: scale(1.1);
    }

    .galeria-overlay {
        position: absolute;
        inset: 0;
        background-color: rgba(0, 0, 0, 0.2);
        opacity: 0;
        transition: opacity 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .galeria-item:hover .galeria-overlay {
        opacity: 1;
    }

    .zoom-icon {
        color: white;
        font-size: 1.875rem;
    }

    .no-images {
        grid-column: 1 / -1;
        text-align: center;
    }

    /* Modal Styles */
    .galeria-modal {
        padding: 0;
        border: none;
        background: transparent;
        width: 100%;
        height: 100%;
        position: fixed;
        inset: 0;
        overflow: hidden;
    }

    .galeria-modal::backdrop {
        background-color: rgba(0, 0, 0, 0.95);
    }

    .modal-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        position: relative;
        padding: 1rem;
    }

    .modal-close {
        position: absolute;
        top: 1.5rem;
        right: 1.5rem;
        color: white;
        background-color: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(8px);
        border-radius: 9999px;
        width: 3rem;
        height: 3rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 2.5rem;
        transition: all 0.3s ease;
        border: none;
        z-index: 70;
    }

    .modal-close:hover {
        background-color: rgba(255, 255, 255, 0.3);
    }

    .modal-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        height: 100%;
        max-width: 80rem;
        padding-left: 1rem;
        padding-right: 1rem;
        gap: 1rem;
    }

    .modal-nav-btn {
        color: white;
        background-color: rgba(0, 0, 0, 0.4);
        border-radius: 9999px;
        padding: 0.75rem;
        cursor: pointer;
        transition: all 0.3s ease;
        border: none;
        font-size: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 60;
    }

    .modal-nav-btn:hover {
        background-color: rgba(0, 0, 0, 0.6);
    }

    .modal-image-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        flex: 1;
        height: 100%;
        justify-content: center;
    }

    .modal-image {
        max-width: 100%;
        max-height: 75vh;
        object-fit: contain;
        border-radius: 0.375rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        transition: transform 0.3s ease;
    }

    .img-magnified {
        transform: scale(1.4);
    }
</style>

<script>
    const initGaleria = () => {
        const modal = document.getElementById('modal-galeria') as HTMLDialogElement;
        const modalImg = document.getElementById('modal-img') as HTMLImageElement;
        const galleryContainer = document.getElementById('galeria-fotos');
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        const closeBtn = document.getElementById('close-modal-btn');

        if (!modal || !modalImg || !galleryContainer || !prevBtn || !nextBtn || !closeBtn) return;

        const rawSections = galleryContainer.getAttribute('data-sections');
        const images = JSON.parse(rawSections || '[]');
        let currentIndex = 0;

        function updateModal(index: number) {
            if (images.length === 0) return;
            if (index < 0) index = images.length - 1;
            if (index >= images.length) index = 0;
            
            currentIndex = index;
            const data = images[currentIndex];
            
            if (data && data.image) {
                modalImg.src = data.image;
                modalImg.alt = data.title || '';
            }
            modalImg.classList.remove('img-magnified');
        }

        galleryContainer.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;
            const item = target.closest('.galeria-item') as HTMLElement;
            if (item) {
                const index = parseInt(item.dataset.index || '0');
                updateModal(index);
                modal.showModal();
                document.body.style.overflow = 'hidden';
            }
        });

        prevBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            updateModal(currentIndex - 1);
        });

        nextBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            updateModal(currentIndex + 1);
        });

        const closeModal = () => {
            modal.close();
            document.body.style.overflow = '';
        };

        closeBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            closeModal();
        });

        modalImg.addEventListener('click', (e) => {
            e.stopPropagation();
            modalImg.classList.toggle('img-magnified');
        });

        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });

        document.addEventListener('keydown', (e) => {
            if (!modal.open) return;
            if (e.key === 'ArrowLeft') updateModal(currentIndex - 1);
            if (e.key === 'ArrowRight') updateModal(currentIndex + 1);
            if (e.key === 'Escape') closeModal();
        });

        document.querySelectorAll<HTMLImageElement>('.galeria-img').forEach(img => {
            if (img.complete && img.naturalWidth === 0) {
                const src = img.src;
                img.src = '';
                requestAnimationFrame(() => { img.src = src; });
            }
            img.addEventListener('error', () => {
                if (img.src.includes('cloudinary') && !img.src.includes('f_auto')) {
                    img.src = img.src.replace('/upload/', '/upload/f_auto,q_auto/');
                }
            });
        });
    };

    initGaleria();
    document.addEventListener('astro:page-load', initGaleria);
</script>