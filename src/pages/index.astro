---
import BaseLayout from "../layouts/BaseLayout.astro";
import Rooms from "../components/Inicio/Rooms.astro";
import FondosHome from "../components/fondosHome.astro";
import HistoricCenter from "../components/Inicio/HistoricCenter.astro";
import AndeandLand from "../components/Inicio/AndeanLand.astro";
import GuaranteedStay from "../components/Inicio/GuaranteedStay.astro";

import FormReserva from "../utils/formReserva.astro";

const lang = "es"
const fondoUrl = "https://res.cloudinary.com/dlgeap8h0/image/upload/f_auto,q_auto/v1779832041/baner-terra_pmgdit.webp";

const ogImage = "https://res.cloudinary.com/dlgeap8h0/image/upload/R6M25442_qbs8cv.webp"
const title = "Inicio"
const description = "Disfruta de Terra Andina Colonial Mansion, hotel boutique en el corazón de Cusco. Lujo colonial, confort moderno y una ubicación inmejorable.";
---

<BaseLayout lang={lang}  title={title} description={description} ogImage={ogImage}>
    <FondosHome />
    <main class="home">
        <FormReserva/>

        <HistoricCenter />
        <AndeandLand />
        <Rooms />
        <GuaranteedStay />
    </main>
</BaseLayout>
