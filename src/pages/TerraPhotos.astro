---
import BaseLayout from "../layouts/BaseLayout.astro";
import Fondos from "../components/fondos.astro";
import { terraFotosData } from "../content/TerraFotos";


const optimizeCloudinary = (url: string) => {
  if (!url.includes('cloudinary.com')) return url;
  return url.replace('/upload/', '/upload/f_auto,q_auto,w_800,c_limit/');
};

const ogImage = "https://res.cloudinary.com/dlgeap8h0/image/upload/v1770926175/R6M25442_qbs8cv.webp";
const title = "Terra Photos";

---

<BaseLayout title={title}>
  
  <main>
    <section id="servicios" class="servicios-section-all">
        <h1 class="title-terrafotos">Un Viajes al Corazon del Cusco Colonial</h1>
        <div class="line"></div>
        <p class="parrafo-terra-fotos w-[700px] text-center max-md:w-[80%]">Bienvenidos a Terra Andina Colonial Mansion, donde la elegancia de la piedra y la madera del siglo XVIII se encuentran con el lujo contemporáneo. Ubicados a solo unos pasos del histórico Mercado de San Pedro, ofrecemos una experiencia única de inmersión en el arte y la historia cusqueña.</p>
      <div class="servicios-section"> 
      <div class="container-fotos">
        <div id="servicios-grid" class="servicios-grid" data-fotos={JSON.stringify(terraFotosData)}>
          {terraFotosData.map((servicio, index) => (
            <div class="servicio-card" data-index={index}>
              <div class="carousel-container">
                <div class="carousel-track" id={`carousel-${index}`}>
                  {servicio.images.map((img, imgIndex) => (
                    <img 
                      class="carousel-image" 
                      src={optimizeCloudinary(img)} 
                      alt={`${servicio.title} - imagen ${imgIndex + 1}`}
                      onclick={`openLightbox('${img}', '${servicio.title}')`}
                    />
                  ))}
                </div>
                {servicio.images.length > 1 && (
                  <>
                    <button class="carousel-btn prev" onclick={`moveCarousel(${index}, -1)`}>❮</button>
                    <button class="carousel-btn next" onclick={`moveCarousel(${index}, 1)`}>❯</button>
                  </>
                )}
                <div class="carousel-dots" id={`dots-${index}`}>
                  {servicio.images.map((_, dotIndex) => (
                    <span class="dot" data-dot-index={dotIndex} onclick={`goToSlide(${index}, ${dotIndex})`}></span>
                  ))}
                </div>
              </div>
              <div class="servicio-info">
                <h3 class="servicio-nombre">{servicio.title}</h3>
                <p class="servicio-descripcion">{servicio.descripcion}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
        </div>
    </section>
  </main>

  <div id="lightbox" class="lightbox" onclick="closeLightbox()">
    <span class="close-lightbox" onclick="closeLightbox()">&times;</span>
    <img class="lightbox-img" id="lightboxImg" alt="Imagen expandida">
    <div class="lightbox-caption" id="lightboxCaption"></div>
  </div>
</BaseLayout>

<script is:inline>
const grid = document.getElementById('servicios-grid');
const terraFotosData = JSON.parse(grid.dataset.fotos);

const currentSlides = {};

function initCarousel(index, totalSlides) {
  if (currentSlides[index] === undefined) {
    currentSlides[index] = 0;
  }
  updateCarousel(index, totalSlides);
}

function updateCarousel(index, totalSlides) {
  const track = document.getElementById(`carousel-${index}`);
  if (!track) return;

  const slideWidth = track.parentElement.clientWidth; 
  track.style.transform = `translateX(-${currentSlides[index] * slideWidth}px)`;

  const dots = document.querySelectorAll(`#dots-${index} .dot`);
  dots.forEach((dot, i) => {
    dot.classList.toggle('active', i === currentSlides[index]);
  });
}
  function moveCarousel(index, direction) {
    const servicio = terraFotosData[index];
    const totalSlides = servicio.images.length;
    
    let newIndex = currentSlides[index] + direction;
    if (newIndex < 0) newIndex = totalSlides - 1;
    if (newIndex >= totalSlides) newIndex = 0;
    
    currentSlides[index] = newIndex;
    updateCarousel(index, totalSlides);
  }
  
  function goToSlide(index, slideIndex) {
    const servicio = terraFotosData[index];
    const totalSlides = servicio.images.length;
    
    currentSlides[index] = slideIndex;
    updateCarousel(index, totalSlides);
  }
  
  function openLightbox(imagenUrl, titulo) {
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg');
    const lightboxCaption = document.getElementById('lightboxCaption');
    
    lightbox.style.display = 'flex';
    lightboxImg.src = imagenUrl;
    lightboxCaption.textContent = titulo;
    document.body.style.overflow = 'hidden';
  }
  
  function closeLightbox() {
    const lightbox = document.getElementById('lightbox');
    lightbox.style.display = 'none';
    document.body.style.overflow = 'auto';
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    terraFotosData.forEach((servicio, index) => {
      initCarousel(index, servicio.images.length);
      
      window.addEventListener('resize', () => {
        updateCarousel(index, servicio.images.length);
      });
    });
  });
  
  window.moveCarousel = moveCarousel;
  window.goToSlide = goToSlide;
  window.openLightbox = openLightbox;
  window.closeLightbox = closeLightbox;
  
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>

<style>

.line{
    width: 200px;
    height: 6px;
    margin-top: 12px;
    border-radius: 20px;
    background-color: rgb(204, 135, 56);
}
  .servicios-section-all {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .title-terrafotos{
    font-size: 40px;
    text-align: center;
    padding: 0px 60px;
    margin-top: 60px;
    font-weight: 500;
    color:rgb(66, 66, 66)
  }

  .parrafo-terra-fotos{
    font-size: 15px;
    margin-top: 40px;
    color: rgb(54, 54, 54);
  }

  .servicios-section {
    background-color: rgba(255, 255, 255, 0.9);
    padding: 60px 60px;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .container-fotos {
    width: 1500px;
    max-width: 100%;
  }
  
  .servicios-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    padding: 40px 0;
  }
  
  /* Carrusel */
  .carousel-container {
    position: relative;
    width: 100%;
    height: 250px;
    overflow: hidden;
    border-radius: 10px;
  }
  
  .carousel-track {
    display: flex;
    transition: transform 0.3s ease;
    height: 100%;
  }
  
  .carousel-image {
  min-width: 100%;   
  width: 100%;
  flex-shrink: 0;
  object-fit: cover;
  cursor: pointer;
  transition: transform 0.2s ease;
}
  
  .carousel-image:hover {
    transform: scale(1.02);
  }
  
  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(27, 27, 27, 0.685);
    color: white;
    border: none;
    font-size: 13px;
    padding: 10px 15px;
    cursor: pointer;
    border-radius: 50%;
    transition: background 0.3s ease;
    z-index: 10;
  }
  
  .carousel-btn:hover {
    background: rgba(0, 0, 0, 0.8);
  }
  
  .prev {
    left: 10px;
  }
  
  .next {
    right: 10px;
  }
  
  .carousel-dots {
    position: absolute;
    bottom: 10px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 8px;
  }
  
  .dot {
    width: 10px;
    height: 10px;
    background: rgba(255, 255, 255, 0.5);
    border-radius: 50%;
    cursor: pointer;
    transition: background 0.3s ease;
  }
  
  .dot.active {
    background: white;
  }
  
  .servicio-card {
    display: flex;
    flex-direction: column;
    gap: 20px;
    border-radius: 10px;
    background-color: rgba(238, 238, 238, 0.8);
    padding: 20px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .servicio-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
  }
  
  .servicio-nombre {
    font-size: 1.5em;
    color: #000;
    font-weight: 600;
    margin-bottom: 10px;
  }
  
  .servicio-descripcion {
    font-size: 0.95em;
    color: #555;
    line-height: 1.5;
  }
  
  .lightbox {
    display: none;
    flex-direction: column;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.9);
    z-index: 2000;
    justify-content: center;
    align-items: center;
    cursor: pointer;
  }
  
  .lightbox-img {
    max-width: 90%;
    max-height: 85%;
    object-fit: contain;
    border-radius: 8px;
  }
  
  .lightbox-caption {
    color: white;
    text-align: center;
    margin-top: 20px;
    font-size: 1.2em;
    background: rgba(0, 0, 0, 0.6);
    padding: 10px 20px;
    border-radius: 30px;
  }
  
  .close-lightbox {
    position: absolute;
    top: 20px;
    right: 40px;
    color: white;
    font-size: 50px;
    cursor: pointer;
  }
  
  /* Responsive */
  @media (max-width: 768px) {
    .servicios-section {
      padding: 40px 20px;
    }
    
    .servicios-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    
    .carousel-container {
      height: 220px;
    }
  }
</style>